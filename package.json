// 2. Fetch Album Tracks/Songs via iTunes API
app.get("/api/album-tracks/:id", async (req, res) => {
  const { id } = req.params;
  if (!id) {
    return res.status(400).json({ error: "Album ID is required" });
  }

  try {
    const lookupUrl = `https://itunes.apple.com/lookup?id=${id}&entity=song`;
    const response = await fetch(lookupUrl);
    if (!response.ok) {
      throw new Error(`iTunes lookup responded with status ${response.status}`);
    }

    const data = (await response.json()) as {
      results: {
        wrapperType: string;
        trackName?: string;
        trackTimeMillis?: number;
        trackNumber?: number;
        previewUrl?: string;
      }[];
    };

    // Filter results to only song entries
    const songs = data.results
      .filter((item) => item.wrapperType === "track" && item.trackName)
      .map((item) => {
        const durationMin = item.trackTimeMillis
          ? Math.floor(item.trackTimeMillis / 60000)
          : 0;
        const durationSec = item.trackTimeMillis
          ? Math.floor((item.trackTimeMillis % 60000) / 1000)
          : 0;
        const durationStr = `${durationMin}:${durationSec.toString().padStart(2, "0")}`;

        return {
          title: item.trackName!,
          duration: durationStr,
          trackNumber: item.trackNumber || 0,
          previewUrl: item.previewUrl || null,
        };
      })
      .sort((a, b) => a.trackNumber - b.trackNumber);

    res.json({ tracklist: songs });
  } catch (error: any) {
    console.error("Error looking up album tracks:", error);
    res.status(500).json({ error: "Failed to load album tracks", details: error.message });
  }
});

// 2.5. Fetch Artist Details, Albums, and Singles/Songs via Apple Music with fallback to iTunes
app.get("/api/artists/:id", async (req, res) => {
  const { id } = req.params;
  const storefront = (req.query.storefront as string) || "us";
  if (!id) {
    return res.status(400).json({ error: "Artist ID is required" });
  }

  const cleanId = id.startsWith("artist-") ? id.replace("artist-", "") : id;
  const developerToken = process.env.APPLE_MUSIC_DEVELOPER_TOKEN;

  if (developerToken) {
    try {
      // Fetch Artist, Albums, and Songs in parallel
      const artistUrl = `https://api.music.apple.com/v1/catalog/${storefront}/artists/${cleanId}`;
      const albumsUrl = `https://api.music.apple.com/v1/catalog/${storefront}/artists/${cleanId}/albums?limit=50`;
      const songsUrl = `https://api.music.apple.com/v1/catalog/${storefront}/artists/${cleanId}/songs?limit=50`;

      const [artistRes, albumsRes, songsRes] = await Promise.all([
        fetch(artistUrl, { headers: { "Authorization": `Bearer ${developerToken}` } }),
        fetch(albumsUrl, { headers: { "Authorization": `Bearer ${developerToken}` } }),
        fetch(songsUrl, { headers: { "Authorization": `Bearer ${developerToken}` } })
      ]);

      if (artistRes.ok) {
        const artistData = await artistRes.json() as any;
        const albumsData = albumsRes.ok ? await albumsRes.json() as any : null;
        const songsData = songsRes.ok ? await songsRes.json() as any : null;

        const artistItem = artistData.data?.[0];
        if (artistItem) {
          const artistName = artistItem.attributes?.name || "Unknown Artist";
          const genres = artistItem.attributes?.genreNames || [];
          
          let artistImageUrl = getArtistImageUrl(artistItem);
          if (artistImageUrl.includes("unsplash.com")) {
            artistImageUrl = await scrapeArtistImageUrl(cleanId, artistName);
          }

          const albums: any[] = [];
          if (albumsData?.data) {
            albumsData.data.forEach((item: any) => {
              const artUrl = item.attributes?.artwork?.url || "";
              const coverUrl = artUrl ? artUrl.replace("{w}x{h}", "600x600") : "";
              albums.push({
                id: String(item.id),
                name: item.attributes?.name || "Unknown Album",
                artist: item.attributes?.artistName || artistName,
                coverUrl,
                releaseYear: item.attributes?.releaseDate ? item.attributes.releaseDate.split("-")[0] : "N/A",
                genres: item.attributes?.genreNames || ["Music"],
                type: "album"
              });
            });
          }

          const songs: any[] = [];
          if (songsData?.data) {
            songsData.data.forEach((item: any) => {
              const artUrl = item.attributes?.artwork?.url || "";
              const coverUrl = artUrl ? artUrl.replace("{w}x{h}", "600x600") : "";
              songs.push({
                id: `song-${item.id}`,
                name: item.attributes?.name || "Unknown Song",
                artist: item.attributes?.artistName || artistName,
                coverUrl,
                releaseYear: item.attributes?.releaseDate ? item.attributes.releaseDate.split("-")[0] : "N/A",
                genres: item.attributes?.genreNames || ["Music"],
                type: "song"
              });
            });
          }

          return res.json({
            artist: {
              id: `artist-${cleanId}`,
              name: artistName,
              genres,
              imageUrl: artistImageUrl
            },
            albums,
            singles: songs
          });
        }
      }
    } catch (apiError) {
      console.error("Apple Music Catalog API artist lookup exception:", apiError);
    }
  }

  // Fallback to iTunes Lookup API
  try {
    const storefrontCountry = storefront.toLowerCase();
    const albumsLookupUrl = `https://itunes.apple.com/lookup?id=${cleanId}&entity=album&limit=50&country=${storefrontCountry}`;
    const songsLookupUrl = `https://itunes.apple.com/lookup?id=${cleanId}&entity=song&limit=50&country=${storefrontCountry}`;

    const [albumsRes, songsRes] = await Promise.all([
      fetch(albumsLookupUrl),
      fetch(songsLookupUrl)
    ]);

    if (!albumsRes.ok) {
      throw new Error(`iTunes albums lookup failed with status ${albumsRes.status}`);
    }

    const albumsData = await albumsRes.json() as any;
    const songsData = songsRes.ok ? await songsRes.json() as any : { results: [] };

    const artistInfo = (albumsData.results || []).find((item: any) => item.wrapperType === "artist");
    const artistName = artistInfo?.artistName || "Unknown Artist";
    const genres = artistInfo?.primaryGenreName ? [artistInfo.primaryGenreName] : [];

    const albums = (albumsData.results || [])
      .filter((item: any) => item.wrapperType === "collection")
      .map((item: any) => {
        const highResArt = item.artworkUrl100
          ? item.artworkUrl100.replace("100x100bb.jpg", "600x600bb.jpg")
          : "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?w=400";
        return {
          id: String(item.collectionId),
          name: item.collectionName || "Unknown Album",
          artist: item.artistName || artistName,
          coverUrl: highResArt,
          releaseYear: item.releaseDate ? item.releaseDate.split("-")[0] : "N/A",
          genres: item.primaryGenreName ? [item.primaryGenreName] : ["Music"],
          type: "album"
        };
      });

    const songs = (songsData.results || [])
      .filter((item: any) => item.wrapperType === "track")
      .map((item: any) => {
        const highResArt = item.artworkUrl100
          ? item.artworkUrl100.replace("100x100bb.jpg", "600x600bb.jpg")
          : "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?w=400";
        return {
          id: `song-${item.trackId}`,
          name: item.trackName || "Unknown Song",
          artist: item.artistName || artistName,
          coverUrl: highResArt,
          releaseYear: item.releaseDate ? item.releaseDate.split("-")[0] : "N/A",
          genres: item.primaryGenreName ? [item.primaryGenreName] : ["Music"],
          type: "song"
        };
      });

    const artistImageUrl = await scrapeArtistImageUrl(cleanId, artistName);

    res.json({
      artist: {
        id: `artist-${cleanId}`,
        name: artistName,
        genres,
        imageUrl: artistImageUrl
      },
      albums,
      singles: songs
    });
  } catch (error: any) {
    console.error("Error looking up artist:", error);
    res.status(500).json({ error: "Failed to load artist details", details: error.message });
  }
});

